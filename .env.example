PORT=5000
NODE_ENV=development
# Render/production: set MONGO_URI in the service Environment (or DATABASE_URL).
MONGO_URI=mongodb://localhost:27017/cvbuilder
CLIENT_URL=http://localhost:3000
JWT_ACCESS_SECRET=your_jwt_access_secret_development_only
JWT_REFRESH_SECRET=your_jwt_refresh_secret_development_only
GITHUB_CLIENT_ID=github_client_id
GITHUB_CLIENT_SECRET=github_secret_id
GITHUB_CALLBACK_URL=http://localhost:5000/api/auth/github/callback
GOOGLE_CLIENT_ID=google_client_id
GOOGLE_CLIENT_SECRET=google_secret_id
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
GEMINI_API_KEY=your_gemini_api_key
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
